# 根目录 .gitignore 文件

# ==================== 构建产物 ====================
# Docker 镜像导出文件
ecommerce/*.tar
ecommerce/*.tar.gz

# Docker 构建缓存
ecommerce/.docker-build-cache/

# ==================== 依赖目录 ====================
# Python
backend/__pycache__/
backend/*.pyc
backend/.venv/
backend/venv/
backend/env/

# Node.js
frontend/node_modules/
frontend/dist/
frontend/build/

# ==================== 环境配置 ====================
# 环境变量文件
backend/.env
backend/.env.local
backend/.env.*.local

# 日志文件
*.log
logs/

# ==================== IDE 配置 ====================
.idea/
.vscode/
*.iml
*.ipr
*.iws

# ==================== 操作系统文件 ====================
.DS_Store
Thumbs.db
desktop.ini

# ==================== 临时文件 ====================
tmp/
temp/
*.tmp
*.swp
*.swo
*~

# ==================== 测试覆盖率 ====================
coverage/
htmlcov/
.pytest_cache/
.mypy_cache/

# ==================== Jenkins 工作空间 ====================
workspace/
.jenkins/
